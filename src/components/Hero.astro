---
/* Hero Component */
import { Picture } from 'astro:assets';
import heroImage from '../assets/hero.jpg';
---
<section class="hero-section">
  <!-- Full-screen background image with blur & dark overlay -->
  <div class="hero-bg-wrapper">
    <Picture 
      src={heroImage} 
      formats={['webp']}
      widths={[640, 991, 1600]}
      sizes="(max-width: 640px) 640px, (max-width: 991px) 991px, 1600px"
      alt="FindFein Cafe Atmosphere" 
      class="hero-bg-img" 
      fetchpriority="high" 
      loading="eager" 
      decoding="async" 
    />
    <div class="hero-bg-overlay"></div>
  </div>
  
  <div class="container hero-container">
    <div class="hero-content">
      <span class="hero-eyebrow">EST. 2025 · SEMARANG</span>
      
      <h1 class="hero-title">
        Find Your <span class="word-rotator">
          <span class="word">Moment</span>
          <span class="word">Space</span>
          <span class="word">Caffeine</span>
        </span>, <br />
        Find<span class="accent">Fein.</span>
      </h1>
      
      <p class="hero-description">
        Kopi premium, suasana industrial minimalis hangat, dan ruang WFC ternyaman di Semarang.
      </p>
      
      <div class="hero-actions">
        <a href="#menu" class="btn btn-gold hero-btn-primary">
          <i class="ph ph-coffee" aria-hidden="true"></i>
          <span>Explore Menu</span>
        </a>
        <a href="https://wa.me/6281234567890" target="_blank" rel="noopener noreferrer" class="btn btn-secondary hero-btn-secondary">
          <i class="ph ph-whatsapp-logo" aria-hidden="true"></i>
          <span>Hubungi Kami</span>
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .hero-section {
    height: 100vh; /* Fallback */
    height: 100svh; /* Prevent resize jump on mobile scroll */
    min-height: 600px; /* Safe viewport height */
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
    background-color: var(--bg-color);
  }
  
  /* Background with blur and overlay */
  .hero-bg-wrapper {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
    overflow: hidden;
  }
  
  .hero-bg-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: blur(8px) brightness(0.55) contrast(1.05); /* Brighter blur for visibility */
    transform: scale(1.05); /* Prevents leakage of white edges */
  }
  
  .hero-bg-overlay {
    position: absolute;
    inset: 0;
    /* Lighter overlays to let the background image be clearly visible */
    background: radial-gradient(circle at center, rgba(12, 10, 9, 0.2) 0%, rgba(12, 10, 9, 0.55) 100%),
                linear-gradient(to bottom, rgba(12, 10, 9, 0.35) 0%, transparent 60%, rgba(12, 10, 9, 0.8) 100%);
    z-index: 2;
  }
  
  .hero-container {
    position: relative;
    z-index: 3;
    display: flex;
    justify-content: center;
    align-items: center;
    width: 100%;
  }
  
  /* Centered Typography content */
  .hero-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    max-width: 720px;
    width: 100%;
  }
  
  .hero-eyebrow {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.25em;
    color: var(--accent-gold);
    text-transform: uppercase;
    margin-bottom: 1.5rem;
    display: inline-block;
  }
  
  .hero-title {
    font-size: clamp(2.5rem, 5.2vw, 4.4rem);
    font-weight: 800;
    line-height: 1.15;
    letter-spacing: -0.03em;
    color: var(--text-primary);
    margin-bottom: 1.5rem;
    text-shadow: 0 4px 20px rgba(0, 0, 0, 0.7); /* Enhance readability */
  }
  
  .hero-title .accent {
    color: var(--accent-gold);
  }
  
  /* Word Rotator 3D Flip Anim */
  .word-rotator {
    display: inline-block;
    position: relative;
    perspective: 400px; /* Softer, more realistic 3D depth */
    height: 1.1em;
    vertical-align: bottom;
    text-align: center;
    margin-right: 0.15em;
    overflow: visible;
    width: 5.4ch; /* Static width to prevent CLS before JS loads */
  }
  
  .word {
    position: absolute;
    left: 50%;
    bottom: 0.05em; /* Shift slightly up to align with baseline of surrounding text */
    opacity: 0;
    transform: translateX(-50%) rotateX(90deg); /* Centered and folded up */
    transform-origin: 50% 0%; /* Rotates around the top edge */
    transition: opacity 0.7s cubic-bezier(0.16, 1, 0.3, 1), transform 0.7s cubic-bezier(0.16, 1, 0.3, 1);
    display: inline-block;
    white-space: nowrap;
    color: var(--accent-gold);
    backface-visibility: hidden;
  }
  
  .word.active {
    opacity: 1;
    transform: translateX(-50%) rotateX(0deg);
    transform-origin: 50% 0%;
  }
  
  .word.exit {
    opacity: 0;
    transform: translateX(-50%) rotateX(-90deg); /* Centered and folded down */
    transform-origin: 50% 100%; /* Rotates around the bottom edge */
    transition: opacity 0.6s cubic-bezier(0.16, 1, 0.3, 1), transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }
  
  .hero-description {
    font-size: clamp(1rem, 1.25vw, 1.25rem);
    color: var(--text-secondary);
    line-height: 1.6;
    max-width: 48ch;
    margin-bottom: 3rem;
    text-shadow: 0 2px 10px rgba(0, 0, 0, 0.6); /* Enhance readability */
  }
  
  .hero-actions {
    display: flex;
    gap: 1.2rem;
    justify-content: center;
    width: 100%;
  }
  
  .hero-btn-primary {
    border-radius: var(--radius-pill);
    padding: 0.9rem 2.2rem;
    box-shadow: 0 4px 20px rgba(197, 165, 127, 0.25);
  }
  
  .hero-btn-secondary {
    border-radius: var(--radius-pill);
    padding: 0.9rem 2.2rem;
    background-color: rgba(255, 255, 255, 0.05);
    backdrop-filter: blur(8px);
    border: 1px solid rgba(255, 255, 255, 0.1);
  }
  
  .hero-btn-secondary:hover {
    background-color: rgba(255, 255, 255, 0.12);
    border-color: rgba(255, 255, 255, 0.25);
  }
  
  /* Responsiveness */
  @media (max-width: 768px) {
    .hero-title {
      font-size: 2.2rem;
    }
    
    .hero-actions {
      flex-direction: column;
      align-items: center;
      gap: 0.8rem;
    }
    
    .hero-btn-primary, .hero-btn-secondary {
      width: 100%;
      max-width: 280px;
      padding: 0.8rem 1.6rem;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const rotator = document.querySelector('.word-rotator') as HTMLElement | null;
    if (!rotator) return;
    
    const words = rotator.querySelectorAll('.word') as NodeListOf<HTMLElement>;
    if (words.length === 0) return;
    
    let currentIndex = 0;
    
    // Function to calculate and set the maximum width once to avoid layout shifts (0 CLS)
    const setRotatorWidth = () => {
      let maxWidth = 0;
      words.forEach(w => {
        // Temporary clean width measurement
        w.style.position = 'absolute';
        const width = w.offsetWidth;
        if (width > maxWidth) {
          maxWidth = width;
        }
      });
      rotator.style.width = maxWidth + 'px';
    };
    
    // Set first word active and measure
    words.forEach((w, i) => {
      if (i === 0) {
        w.classList.add('active');
      } else {
        w.classList.remove('active');
      }
    });
    
    // Initial measure
    setRotatorWidth();
    
    // Recalculate on load and resize
    window.addEventListener('load', setRotatorWidth);
    window.addEventListener('resize', setRotatorWidth);
    
    // Periodically switch words
    setInterval(() => {
      const activeWord = rotator.querySelector('.word.active') as HTMLElement | null;
      if (!activeWord) return;
      
      const nextIndex = (currentIndex + 1) % words.length;
      const nextWord = words[nextIndex];
      if (!nextWord) return;
      
      // Exit active word
      activeWord.classList.remove('active');
      activeWord.classList.add('exit');
      
      // Enter next word
      nextWord.classList.add('active');
      nextWord.classList.remove('exit');
      
      // Clean up exit class
      setTimeout(() => {
        activeWord.classList.remove('exit');
      }, 700);
      
      currentIndex = nextIndex;
    }, 3000);
  });
</script>
