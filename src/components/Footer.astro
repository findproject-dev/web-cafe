---
/* Footer & Final CTA Component */
---
<footer class="footer-wrapper">
  
  <!-- Final CTA Section (High Conversion Focus) -->
  <div class="cta-banner-container container">
    <div class="cta-banner">
      <div class="cta-content">
        <span class="mono-eyebrow accent-color">YOUR SECOND HOME</span>
        <h2 class="cta-title">Ready to Find <br class="mobile-only" />Your Moment?</h2>
        <p class="cta-subtitle">Kunjungi kami hari ini untuk kopi berkualitas, suasana industrial yang tenang, dan tempat WFC ternyaman di Semarang.</p>
        
        <div class="cta-buttons">
          <a href="https://wa.me/6281234567890" target="_blank" rel="noopener noreferrer" class="btn btn-gold cta-btn-wa">
            <i class="ph ph-whatsapp-logo" aria-hidden="true"></i>
            <span>Hubungi WhatsApp</span>
          </a>
          <a href="#menu" class="btn btn-primary cta-btn-menu">
            <i class="ph ph-coffee" aria-hidden="true"></i>
            <span>Lihat Menu</span>
          </a>
          <a href="#location" class="btn btn-secondary cta-btn-visit">
            <i class="ph ph-map-pin" aria-hidden="true"></i>
            <span>Kunjungi Cafe</span>
          </a>
        </div>
      </div>
    </div>
  </div>
  
  <!-- Divider -->
  <div class="container">
    <div class="footer-divider"></div>
  </div>
  
  <!-- Main Footer Content -->
  <div class="footer-content-container container">
    <div class="footer-flex-grid">
      
      <!-- Col 1: Brand Info -->
      <div class="footer-brand">
        <a href="#" class="brand-logo">
          <span class="brand-text">FIND<span class="accent">FEIN.</span></span>
          <span class="brand-sub">EST. 2025 · SEMARANG</span>
        </a>
        <p class="brand-description">
          Ruang singgah industrial minimalis modern untuk fokus, berbincang, dan menikmati waktu sendiri.
        </p>
        <span class="copyright">
          &copy; 2026 FindFein. All rights reserved. <br />
          Built by <a href="https://galacode.id" target="_blank" rel="noopener noreferrer" class="galacode-link">Galacode</a>.
        </span>
      </div>
      
      <!-- Col 2: Navigation Links -->
      <div class="footer-links">
        <h4 class="footer-col-title">Navigation</h4>
        <ul class="link-list">
          <li><a href="#about">About Us</a></li>
          <li><a href="#menu">Curated Menu</a></li>
          <li><a href="#ambience">Our Ambience</a></li>
          <li><a href="#location">Find Location</a></li>
          <li><a href="#faq">Frequently Asked Questions</a></li>
        </ul>
      </div>
      
      <!-- Col 3: Contact & Socials -->
      <div class="footer-contact">
        <h4 class="footer-col-title">Contact & Socials</h4>
        <ul class="contact-list">
          <li>
            <a href="https://wa.me/6281234567890" target="_blank" rel="noopener noreferrer" class="contact-link-item">
              <i class="ph ph-whatsapp-logo" aria-hidden="true"></i>
              <span>WhatsApp: 0812-3456-7890</span>
            </a>
          </li>
          <li>
            <a href="https://instagram.com/galacode.id" target="_blank" rel="noopener noreferrer" class="contact-link-item">
              <i class="ph ph-instagram-logo" aria-hidden="true"></i>
              <span>Instagram: @galacode.id</span>
            </a>
          </li>
          <li>
            <a href="https://tiktok.com/@galacode.id" target="_blank" rel="noopener noreferrer" class="contact-link-item">
              <i class="ph ph-tiktok-logo" aria-hidden="true"></i>
              <span>TikTok: @galacode.id</span>
            </a>
          </li>
          <li>
            <a href="mailto:hi.findya@gmail.com" class="contact-link-item">
              <i class="ph ph-envelope" aria-hidden="true"></i>
              <span>Email: hi.findya@gmail.com</span>
            </a>
          </li>
        </ul>
      </div>
      
    </div>
  </div>
  
</footer>

<style>
  .footer-wrapper {
    background-color: var(--bg-color);
    border-top: 1px solid var(--border-color);
    padding-top: 8rem;
    padding-bottom: 4rem;
  }
  
  /* CTA Banner */
  .cta-banner-container {
    margin-bottom: 6rem;
  }
  
  .cta-banner {
    background-color: var(--bg-surface);
    border: 1px solid var(--border-color);
    border-radius: 2rem;
    padding: 5rem;
    text-align: center;
    position: relative;
    overflow: hidden;
    box-shadow: 0 10px 45px rgba(0, 0, 0, 0.3);
  }
  
  .cta-banner::after {
    /* Subtle background radial glow */
    content: "";
    position: absolute;
    bottom: -150px;
    left: 50%;
    transform: translateX(-50%);
    width: 600px;
    height: 300px;
    background: radial-gradient(circle, rgba(197, 165, 127, 0.05) 0%, transparent 70%);
    pointer-events: none;
    z-index: 1;
  }
  
  .cta-content {
    position: relative;
    z-index: 2;
    max-width: 700px;
    margin: 0 auto;
  }
  
  .accent-color {
    color: var(--accent-gold);
  }
  
  .cta-title {
    font-size: clamp(2rem, 4vw, 3.2rem);
    font-weight: 800;
    margin-bottom: 1.5rem;
    letter-spacing: -0.03em;
  }
  
  .cta-subtitle {
    font-size: 1.1rem;
    color: var(--text-secondary);
    line-height: 1.6;
    margin-bottom: 3rem;
  }
  
  .cta-buttons {
    display: flex;
    justify-content: center;
    gap: 1.2rem;
    flex-wrap: wrap;
  }
  
  .cta-btn-wa {
    border-radius: var(--radius-pill);
    padding: 0.9rem 1.8rem;
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.2);
  }
  
  .cta-btn-menu {
    border-radius: var(--radius-pill);
    padding: 0.9rem 1.8rem;
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.1);
  }
  
  .cta-btn-visit {
    border-radius: var(--radius-pill);
    padding: 0.9rem 1.8rem;
  }
  
  .cta-buttons i {
    font-size: 1.1rem;
  }
  
  /* Divider */
  .footer-divider {
    height: 1px;
    background-color: var(--border-color);
    margin-bottom: 5rem;
  }
  
  /* Main Footer Columns */
  .footer-flex-grid {
    display: flex;
    justify-content: space-between;
    gap: 4rem;
    width: 100%;
  }
  
  .footer-brand {
    flex: 1.5;
  }
  
  .footer-links {
    flex: 1;
  }
  
  .footer-contact {
    flex: 1;
  }
  
  .brand-logo {
    display: flex;
    flex-direction: column;
    line-height: 1;
    margin-bottom: 1.5rem;
  }
  
  .brand-text {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 1.5rem;
    letter-spacing: -0.03em;
    color: var(--text-primary);
  }
  
  .brand-text .accent {
    color: var(--accent-gold);
  }
  
  .brand-sub {
    font-family: var(--font-mono);
    font-size: 0.55rem;
    letter-spacing: 0.2em;
    color: var(--text-muted);
    margin-top: 0.15rem;
  }
  
  .brand-description {
    font-size: 0.9rem;
    line-height: 1.5;
    color: var(--text-secondary);
    margin-bottom: 2rem;
    max-width: 32ch;
  }
  
  .copyright {
    display: block;
    font-size: 0.75rem;
    color: var(--text-muted);
    line-height: 1.5;
  }
  
  .galacode-link {
    color: var(--text-secondary);
    font-weight: 500;
  }
  
  .galacode-link:hover {
    color: var(--accent-gold);
  }
  
  .footer-col-title {
    font-family: var(--font-display);
    font-size: 0.9rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-primary);
    margin-bottom: 2rem;
  }
  
  .link-list, .contact-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  
  .link-list a {
    font-size: 0.9rem;
    color: var(--text-secondary);
  }
  
  .link-list a:hover {
    color: var(--accent-gold);
    transform: translateX(3px);
  }
  
  .contact-link-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.9rem;
    color: var(--text-secondary);
  }
  
  .contact-link-item i {
    font-size: 1.1rem;
    color: var(--accent-gold);
  }
  
  .contact-link-item:hover {
    color: var(--text-primary);
  }
  
  /* Responsiveness */
  @media (max-width: 991px) {
    .footer-flex-grid {
      gap: 2rem;
    }
    .footer-brand {
      flex: 1.2;
    }
  }
  
  @media (max-width: 768px) {
    .footer-wrapper {
      padding-top: 5rem;
      padding-bottom: 3rem;
    }
    
    .cta-banner {
      padding: 3rem 1.5rem;
    }
    
    .cta-title {
      font-size: 1.8rem;
    }
    
    .cta-buttons {
      flex-direction: column;
      align-items: stretch;
      gap: 0.75rem;
    }
    
    .footer-flex-grid {
      flex-direction: column;
      gap: 3rem;
    }
    
    .footer-brand, .footer-links, .footer-contact {
      flex: none;
      width: 100%;
    }
    
    .footer-col-title {
      margin-bottom: 1.25rem;
    }
  }
</style>
