---
/* Navbar Component */
---
<header class="navbar-wrapper">
  <div class="container navbar-container">
    <a href="#" class="brand-logo">
      <span class="brand-text">FIND<span class="accent">FEIN.</span></span>
      <span class="brand-sub">EST. 2025</span>
    </a>
    
    <nav class="nav-links">
      <a href="#about" class="nav-link">About</a>
      <a href="#menu" class="nav-link">Menu</a>
      <a href="#ambience" class="nav-link">Ambience</a>
      <a href="#location" class="nav-link">Location</a>
      <a href="#faq" class="nav-link">FAQ</a>
    </nav>
    
    <div class="nav-actions">
      <a href="https://wa.me/6281234567890" target="_blank" rel="noopener noreferrer" class="btn btn-primary nav-cta">
        <span>Hubungi Kami</span>
        <i class="ph ph-arrow-up-right" aria-hidden="true"></i>
      </a>
      
      <button class="mobile-toggle" aria-label="Toggle Navigation">
        <span class="line line-1"></span>
        <span class="line line-2"></span>
      </button>
    </div>
  </div>
  
  <!-- Mobile Navigation Overlay -->
  <div class="mobile-overlay">
    <nav class="mobile-nav-links">
      <a href="#about" class="mobile-nav-link">About</a>
      <a href="#menu" class="mobile-nav-link">Menu</a>
      <a href="#ambience" class="mobile-nav-link">Ambience</a>
      <a href="#location" class="mobile-nav-link">Location</a>
      <a href="#faq" class="mobile-nav-link">FAQ</a>
      <a href="https://wa.me/6281234567890" target="_blank" rel="noopener noreferrer" class="btn btn-gold mobile-cta">
        <span>Hubungi Kami</span>
        <i class="ph ph-arrow-up-right" aria-hidden="true"></i>
      </a>
    </nav>
  </div>
</header>

<style>
  .navbar-wrapper {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    z-index: 100;
    transition: 
      top 0.4s cubic-bezier(0.16, 1, 0.3, 1),
      background-color 0.4s cubic-bezier(0.16, 1, 0.3, 1),
      border-color 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    background-color: transparent;
    border-bottom: 1px solid rgba(255, 255, 255, 0.03);
  }
  
  .navbar-container {
    height: 80px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 1.5rem;
    transition: 
      background-color 0.4s cubic-bezier(0.16, 1, 0.3, 1),
      backdrop-filter 0.4s cubic-bezier(0.16, 1, 0.3, 1),
      border-color 0.4s cubic-bezier(0.16, 1, 0.3, 1),
      border-radius 0.4s cubic-bezier(0.16, 1, 0.3, 1),
      box-shadow 0.4s cubic-bezier(0.16, 1, 0.3, 1),
      height 0.4s cubic-bezier(0.16, 1, 0.3, 1),
      width 0.4s cubic-bezier(0.16, 1, 0.3, 1),
      padding 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    background-color: transparent;
    border: 1px solid transparent;
    box-shadow: none;
    border-radius: 0;
    width: 100%;
    max-width: var(--max-width);
    margin: 0 auto;
    position: relative;
    z-index: 100; /* Ensure toggle stays above fullscreen overlay */
  }
  
  /* Reset background container when menu is open */
  .navbar-wrapper.menu-open .navbar-container {
    background-color: transparent;
    backdrop-filter: none;
    border-color: transparent;
    box-shadow: none;
  }
  
  /* Scrolled Floating State */
  .navbar-wrapper.scrolled {
    top: 1.5rem;
    border-bottom: none;
  }
  
  .navbar-wrapper.scrolled .navbar-container {
    background-color: rgba(20, 18, 17, 0.75);
    backdrop-filter: blur(20px);
    border: 1px solid var(--border-color);
    border-radius: 50px;
    height: 65px;
    padding: 0 2rem;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.4);
    width: calc(100% - 3rem);
  }
  
  .brand-logo {
    display: flex;
    flex-direction: column;
    line-height: 1;
  }
  
  .brand-text {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 1.4rem;
    letter-spacing: -0.03em;
    color: var(--text-primary);
  }
  
  .brand-text .accent {
    color: var(--accent-gold);
  }
  
  .brand-sub {
    font-family: var(--font-mono);
    font-size: 0.55rem;
    letter-spacing: 0.2em;
    color: var(--text-muted);
    margin-top: 0.1rem;
  }
  
  .nav-links {
    display: flex;
    align-items: center;
    gap: 2.5rem;
  }
  
  .nav-link {
    font-family: var(--font-display);
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--text-secondary);
    position: relative;
    padding: 0.25rem 0;
  }
  
  .nav-link:hover {
    color: var(--text-primary);
  }
  
  .nav-link::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 1px;
    background-color: var(--accent-gold);
    transform: scaleX(0);
    transform-origin: right;
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }
  
  .nav-link:hover::after {
    transform: scaleX(1);
    transform-origin: left;
  }
  
  .nav-actions {
    display: flex;
    align-items: center;
    gap: 1rem;
  }
  
  .nav-cta {
    padding: 0.6rem 1.2rem;
    font-size: 0.85rem;
    border-radius: var(--radius-pill);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.1);
  }
  
  .nav-cta i {
    font-size: 0.9rem;
    transition: var(--transition-fast);
  }
  
  .nav-cta:hover i {
    transform: translate(2px, -2px);
  }
  
  /* Mobile Hamburger Toggle */
  .mobile-toggle {
    display: none;
    background: none;
    border: none;
    cursor: pointer;
    width: 24px;
    height: 14px;
    position: relative;
    flex-direction: column;
    justify-content: space-between;
    z-index: 101;
  }
  
  .line {
    width: 100%;
    height: 1.5px;
    background-color: var(--text-primary);
    transition: var(--transition-fast);
  }
  
  /* Mobile Overlay */
  .mobile-overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100dvh;
    background-color: rgba(12, 10, 9, 0.98);
    backdrop-filter: blur(20px);
    z-index: 99;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    pointer-events: none;
    transition: var(--transition-smooth);
  }
  
  .mobile-overlay.active {
    opacity: 1;
    pointer-events: all;
  }
  
  .mobile-nav-links {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2rem;
    transform: translateY(20px);
    transition: var(--transition-smooth);
  }
  
  .mobile-overlay.active .mobile-nav-links {
    transform: translateY(0);
  }
  
  .mobile-nav-link {
    font-family: var(--font-display);
    font-size: 1.8rem;
    font-weight: 600;
    color: var(--text-secondary);
  }
  
  .mobile-nav-link:hover {
    color: var(--accent-gold);
  }
  
  .mobile-cta {
    margin-top: 1rem;
    padding: 0.8rem 2rem;
    border-radius: var(--radius-pill);
  }
  
  /* Responsiveness */
  @media (max-width: 1024px) {
    .nav-links {
      gap: 1.5rem;
    }
  }
  
  @media (max-width: 768px) {
    .navbar-wrapper {
      transition: background-color 0.3s ease, border-color 0.3s ease;
    }

    .navbar-container {
      height: 70px;
      padding: 0 1.2rem;
      transition: 
        background-color 0.3s ease,
        backdrop-filter 0.3s ease,
        border-color 0.3s ease,
        border-radius 0.3s ease,
        box-shadow 0.3s ease;
    }
    
    .navbar-wrapper.scrolled {
      top: 1rem;
    }
    
    .navbar-wrapper.scrolled .navbar-container {
      width: calc(100% - 2rem);
      height: 60px;
      padding: 0 1.2rem;
      border-radius: 50px;
    }
    
    .nav-links, .nav-cta {
      display: none;
    }
    
    .mobile-toggle {
      display: flex;
    }
    
    /* Hamburger active state */
    .mobile-toggle.active .line-1 {
      transform: translateY(6px) rotate(45deg);
    }
    
    .mobile-toggle.active .line-2 {
      transform: translateY(-6px) rotate(-45deg);
    }
  }
</style>

<script>
  const toggle = document.querySelector('.mobile-toggle');
  const overlay = document.querySelector('.mobile-overlay');
  const links = document.querySelectorAll('.mobile-nav-link');
  const navbar = document.querySelector('.navbar-wrapper');
  
  function toggleMenu() {
    toggle?.classList.toggle('active');
    overlay?.classList.toggle('active');
    navbar?.classList.toggle('menu-open');
    document.body.style.overflow = overlay?.classList.contains('active') ? 'hidden' : '';
  }
  
  toggle?.addEventListener('click', toggleMenu);
  
  links.forEach(link => {
    link.addEventListener('click', () => {
      toggleMenu();
    });
  });
  
  // Navbar scroll effect
  window.addEventListener('scroll', () => {
    if (window.scrollY > 50) {
      navbar?.classList.add('scrolled');
    } else {
      navbar?.classList.remove('scrolled');
    }
  });
</script>
